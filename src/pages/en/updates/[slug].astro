---
import Layout from "../../../ui/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const all = await getCollection("updates");
  const en = all.filter((u) => u.data.lang === "en");
  return en.map((u) => ({ params: { slug: u.slug } }));
}

const slug = Astro.params.slug!;
const all = await getCollection("updates");
const entry = all.find((u) => u.data.lang === "en" && u.slug === slug);
if (!entry) throw new Error(`Update not found: ${slug}`);

const { Content } = await entry.render();
---

<Layout lang="en" title={entry.data.title}>
  <a href="/en/updates" class="text-sm text-slate-300 hover:text-white">← Back to Updates</a>

  <h1 class="mt-4 text-3xl font-semibold">{entry.data.title}</h1>
  <p class="mt-2 text-slate-300">{entry.data.summary}</p>

  <div class="mt-6 text-sm text-slate-400">
    {entry.data.date.toISOString().slice(0, 10)} • Project:
    <a
      href={`/en/projects/${entry.data.slugBase}`}
      class="text-slate-200 hover:text-white underline underline-offset-4"
    >
      {entry.data.slugBase}
    </a>
  </div>

  <div class="mt-6">
    <Content />
  </div>
</Layout>